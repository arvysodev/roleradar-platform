GATEWAY_SERVER_PORT=8080

GATEWAY_JWT_ISSUER=http://auth-service:8081
GATEWAY_JWT_AUDIENCE=roleradar-api
GATEWAY_JWK_SET_URI=http://auth-service:8081/.well-known/jwks.json

GATEWAY_ACCESS_TOKEN_COOKIE_NAME=access_token
