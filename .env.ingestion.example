INGESTION_KAFKA_BOOTSTRAP_SERVERS=kafka:29092

INGESTION_SERVER_PORT=8083

INGESTION_SCHEDULING_ENABLED=true
INGESTION_REMOTIVE_CRON=0 0 */8 * * *
INGESTION_ARBEITNOW_CRON=0 0 */2 * * *
INGESTION_ADZUNA_CRON=0 0 */2 * * *

REMOTIVE_BASE_URL=https://remotive.com
REMOTIVE_MAX_JOBS_PER_RUN=10

ARBEITNOW_BASE_URL=https://www.arbeitnow.com
ARBEITNOW_MAX_JOBS_PER_RUN=50
ARBEITNOW_MAX_PAGES_PER_RUN=3

ADZUNA_BASE_URL=https://api.adzuna.com/v1/api
ADZUNA_APP_ID={cannot be shared, present in real .env}
ADZUNA_APP_KEY={cannot be shared, present in real .env}
ADZUNA_COUNTRIES=pl,de,nl,fr,es,it
ADZUNA_MAX_JOBS_PER_RUN=100
ADZUNA_RESULTS_PER_PAGE=50
ADZUNA_MAX_PAGES_PER_RUN=3

INGESTION_KAFKA_TOPIC_VACANCY_UPSERTED=vacancy-upserted
